    "access": "public"
  },
  "scripts": {
    "check": "tsc",
    "compile": "tsup",
    "build": "tsc && tsup",
    "build:watch": "tsup --watch",
    "prepack": "npm run build",
    "prettier": "prettier 'src/**/*.ts' --write",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "docs": "typedoc ./src/index.ts --out ./docs"
